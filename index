async function testConn(){
  var url=document.getElementById('urlInp').value.trim();
  var el=document.getElementById('tres');
  if(!url){ showTR(false,'Please enter a URL first.'); return; }
  el.style.display='block'; el.className='tres'; el.textContent='Testing...';
  try{
    var r=await fetch(url+'?action=ping');
    var d=await r.json();
    showTR(d.success, d.success ? '✓ Connected! '+d.message : 'Error: '+d.error);
  }catch(e){ showTR(false,'Cannot reach URL. Deploy as Web App with access: Anyone.'); }
}
function showTR(ok,msg){
  var el=document.getElementById('tres');
  el.style.display='block';
  el.className='tres '+(ok?'tok':'terr');
  el.textContent=msg;
}
function saveUrl(){
  var url=document.getElementById('urlInp').value.trim();
  if(!url){ showTR(false,'URL cannot be empty.'); return; }
  GS=url; localStorage.setItem(LS_KEY,url);
  closeModal(); setSS('ok','Connected • Google Sheets');
  if(curExec) loadLogs();
}

// SYNC STATUS
function setSS(state,msg){
  document.getElementById('sd').className='sd '+state;
  document.getElementById('sm').textContent=msg;
  var sl=document.getElementById('sl');
  sl.className=state==='off'?'sl':'sl hide';
}
async function syncLog(stop,status,order,notes,idx){
  if(!GS) return;
  setSS('busy','Saving...');
  try{
    var r=await fetch(GS,{method:'POST',body:JSON.stringify({
      action:'logVisit',exec_id:curExec.exec_id,exec_name:curExec.exec_name,
      customer_id:stop.id,customer_name:stop.name,tier:stop.tier,day:curDay,
      date:new Date().toISOString().slice(0,10),status:status,
      order_value:order||0,visit_notes:notes||'',stop_number:idx+1
    })});
    var d=await r.json();
    if(d.success){ setSS('ok','Saved ✓'); setTimeout(function(){ setSS('ok','Connected • Google Sheets'); },2500); }
    else setSS('err','Sync error');
  }catch(e){ setSS('err','Offline - saved locally'); }
}
async function loadLogs(){
  if(!GS||!curExec) return;
  setSS('busy','Loading...');
  try{
    var r=await fetch(GS+'?action=getDayLog&exec_id='+curExec.exec_id+'&day='+encodeURIComponent(curDay)+'&date='+new Date().toISOString().slice(0,10));
    var d=await r.json();
    if(d.success&&d.logs.length){
      d.logs.forEach(function(l){
        var k=curExec.exec_id+'|'+l.customer_id+'|'+curDay;
        ov[k]={status:l.status,order:Number(l.order_value)||0,notes:l.visit_notes||''};
      });
      var stops=curExec.days[curDay]||[];
      renderStops(stops); renderMap(stops); updateStats(stops);
      setSS('ok','Loaded '+d.logs.length+' entries');
      setTimeout(function(){ setSS('ok','Connected • Google Sheets'); },2500);
    } else setSS('ok','Connected • Google Sheets');
  }catch(e){ setSS('err','Could not load from Sheets'); }
}

