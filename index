function doLogin(){
  var pin=document.getElementById('pin').value.trim();
  var err=document.getElementById('lerr');
  err.textContent='';
  if(!selEid){ err.textContent='Please select your name.'; return; }
  if(!pin){ err.textContent='Please enter your PIN.'; return; }
  var cred=CR[selEid];
  if(!cred||pin!==cred.pin){
    err.textContent='Incorrect PIN - please try again.';
    document.getElementById('pin').value=''; document.getElementById('pin').focus(); return;
  }
  curExec=RD[selEid];
  document.getElementById('ls').classList.add('hide');
  document.getElementById('ap').classList.add('on');
  document.getElementById('hpill').textContent=cred.name+' · '+selEid;
  document.getElementById('hsub').textContent=curExec.total_customers+' customers · '+
    curExec.tier_counts.A+'A · '+curExec.tier_counts.B+'B · '+curExec.tier_counts.C+'C';
  var days=['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
  var today=days[new Date().getDay()];
  curDay=DAYS.includes(today)?today:'Monday';
  if(GS) setSS('ok','Connected • Google Sheets'); else setSS('off','Not connected to Google Sheets');
  renderTabs(); selectDay(curDay);
  setTimeout(function(){ map.invalidateSize(); },150);
  if(GS) loadLogs();
}
function doLogout(){
  curExec=null; ov={}; selStop=null; selEid=null; curDay='Monday';
  markers.forEach(function(m){ map.removeLayer(m); }); markers=[];
  if(rLine){ map.removeLayer(rLine); rLine=null; }
  document.getElementById('ap').classList.remove('on');
  document.getElementById('ls').classList.remove('hide');
  var d=document.getElementById('ddtxt'); d.textContent='Choose your name'; d.classList.add('ph');
  document.querySelectorAll('#ddl .opt').forEach(function(o){ o.classList.remove('sel'); });
  document.getElementById('pin').value=''; document.getElementById('lerr').textContent='';
  closeDrawer();
}

