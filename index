<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1"><title>ISI Steel Route Planner</title><link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/><script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script><style>@font-face{font-family:'Ginto';src:url('data:font/otf;base64,') format('opentype');font-weight:400}@font-face{font-family:'Ginto';src:url('data:font/otf;base64,') format('opentype');font-weight:500}@font-face{font-family:'Ginto';src:url('data:font/otf;base64,') format('opentype');font-weight:700}
:root{
  --wh:#dce3eb; --iron:#011e41; --apex:#004a98;
  --green:#2c9942; --blaze:#e0592a; --sapp:#002169;
  --bg:#dce3eb; --surf:#ffffff; --panel:#eef1f6; --hover:#e4e9f0;
  --bd:rgba(1,30,65,.11); --bd2:rgba(1,30,65,.18);
  --t1:#011e41; --t2:#3a5270; --t3:#8099b4;
  --done:#2c9942; --skip:#c0392b;
  --a-bg:#fff0eb; --a-bd:#e0592a; --a-tx:#7a2000;
  --b-bg:#fffbea; --b-bd:#c49a1a; --b-tx:#6b4e00;
  --c-bg:#eaf1fb; --c-bd:#004a98; --c-tx:#003077;
  --font:'Ginto',system-ui,sans-serif;
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;overflow:hidden;background:var(--bg);color:var(--t1);font-family:var(--font)}

/* OVERLAY */
#ov{position:fixed;inset:0;background:rgba(1,30,65,.52);z-index:9000;
  display:flex;align-items:center;justify-content:center;padding:20px}
#ov.hide{display:none!important}

/* MODAL */
.modal{width:100%;max-width:440px;background:var(--surf);border-radius:14px;
  overflow:hidden;box-shadow:0 20px 60px rgba(1,30,65,.3)}
.mhdr{background:var(--iron);padding:18px 22px;display:flex;align-items:center;gap:12px}
.mhdr img{height:30px;width:auto}
.mhdr h3{font-size:14px;font-weight:700;color:var(--wh)}
.mhdr p{font-size:10px;color:rgba(220,227,235,.5);margin-top:1px}
.mbody{padding:20px 22px}
.steps{background:var(--panel);border:1px solid var(--bd);border-radius:10px;
  padding:12px 14px;margin-bottom:14px}
.steps p{font-size:11px;color:var(--t2);line-height:2}
.steps code{background:var(--wh);border:1px solid var(--bd2);border-radius:4px;
  padding:1px 6px;font-family:monospace;font-size:10.5px;color:var(--apex)}
.flbl{display:block;font-size:9px;font-weight:700;color:var(--t3);
  text-transform:uppercase;letter-spacing:1px;margin-bottom:6px}
.finp{width:100%;background:var(--panel);border:1.5px solid var(--bd2);
  border-radius:9px;padding:10px 13px;color:var(--t1);font-family:var(--font);
  font-size:12px;outline:none;transition:border-color .15s}
.finp:focus{border-color:var(--apex)}
.finp::placeholder{color:var(--t3);font-size:11px}
.fhint{font-size:10px;color:var(--t3);margin-top:5px}
.tres{display:none;font-size:11px;font-weight:500;padding:8px 12px;
  border-radius:8px;margin-bottom:12px}
.tok{background:#eaf3de;color:#1a5e2a;border:1px solid #97c459}
.terr{background:#fdeaea;color:#8b1a1a;border:1px solid #e09595}
.mbtns{display:flex;gap:8px;margin-top:14px}
.mbtn{flex:1;padding:10px;border-radius:9px;font-size:12px;font-weight:700;
  cursor:pointer;border:none;font-family:var(--font);transition:all .15s}
.mbtn-p{background:var(--apex);color:white}
.mbtn-p:hover{background:var(--sapp)}
.mbtn-s{background:var(--panel);color:var(--t2);border:1.5px solid var(--bd2)}
.mbtn-s:hover{border-color:var(--apex);color:var(--apex)}

/* LOGIN */
#ls{position:fixed;inset:0;background:var(--bg);z-index:8000;
  display:flex;align-items:center;justify-content:center;padding:20px}
#ls.hide{display:none!important}
.lcard{width:100%;max-width:380px;background:var(--surf);border-radius:18px;
  overflow:hidden;box-shadow:0 16px 50px rgba(1,30,65,.16);border:1px solid var(--bd)}
.ltop{background:var(--iron);padding:30px 28px 24px;
  display:flex;flex-direction:column;align-items:center}
.ltop img{height:38px;width:auto;margin-bottom:14px}
.ltag{font-size:9.5px;color:rgba(220,227,235,.4);
  text-transform:uppercase;letter-spacing:1.2px}
.lbody{padding:24px 26px 26px}
.llbl{display:block;font-size:9px;font-weight:700;color:var(--t3);
  text-transform:uppercase;letter-spacing:1px;margin-bottom:7px}

/* DROPDOWN */
.ddw{position:relative;margin-bottom:16px;z-index:100}
.ddt{width:100%;background:var(--panel);border:1.5px solid var(--bd2);
  border-radius:10px;padding:11px 40px 11px 14px;color:var(--t1);
  font-family:var(--font);font-size:13px;cursor:pointer;text-align:left;
  position:relative;transition:border-color .15s;min-height:44px;
  display:flex;align-items:center;appearance:none;-webkit-appearance:none}
.ddt:hover,.ddt.open{border-color:var(--apex)}
.ddt.open{border-bottom-left-radius:0;border-bottom-right-radius:0}
.ddtxt{flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.ddtxt.ph{color:var(--t3)}
.ddarr{position:absolute;right:14px;top:50%;transform:translateY(-50%);
  pointer-events:none;color:var(--t3);transition:transform .15s;line-height:1}
.ddt.open .ddarr{transform:translateY(-50%) rotate(180deg)}

.ddp{position:absolute;left:0;right:0;top:calc(100% - 1.5px);
  background:var(--surf);border:1.5px solid var(--apex);
  border-top:none;border-bottom-left-radius:10px;border-bottom-right-radius:10px;
  z-index:9999;display:none;flex-direction:column;max-height:220px;overflow:hidden;
  box-shadow:0 10px 30px rgba(1,30,65,.12)}
.ddp.open{display:flex}
.ddsrow{padding:8px 8px 5px;border-bottom:1px solid var(--bd);flex-shrink:0}
.dds{width:100%;background:var(--panel);border:1px solid var(--bd);
  border-radius:7px;padding:7px 11px;color:var(--t1);font-family:var(--font);
  font-size:12px;outline:none}
.dds:focus{border-color:var(--apex)}
.dds::placeholder{color:var(--t3)}
.ddl{overflow-y:auto;flex:1}
.ddl::-webkit-scrollbar{width:4px}
.ddl::-webkit-scrollbar-thumb{background:var(--bd2);border-radius:4px}
.opt{padding:10px 14px;font-size:12.5px;color:var(--t2);cursor:pointer;
  display:flex;justify-content:space-between;align-items:center;
  border-bottom:1px solid var(--bd);transition:background .1s}
.opt:last-child{border-bottom:none}
.opt:hover,.opt.sel{background:var(--hover);color:var(--t1)}
.opt.sel{color:var(--apex);font-weight:500}
.oid{font-size:10px;color:var(--t3);font-family:monospace;margin-left:8px}
.ddnone{padding:14px;text-align:center;font-size:11.5px;color:var(--t3)}

/* PIN */
.plbl{display:block;font-size:9px;font-weight:700;color:var(--t3);
  text-transform:uppercase;letter-spacing:1px;margin-bottom:7px}
.pinp{width:100%;background:var(--panel);border:1.5px solid var(--bd2);
  border-radius:10px;padding:11px 14px;color:var(--t1);font-family:monospace;
  font-size:26px;letter-spacing:14px;text-align:center;outline:none;
  transition:border-color .15s;margin-bottom:10px}
.pinp:focus{border-color:var(--apex)}
.pinp::placeholder{font-size:13px;letter-spacing:3px;color:var(--t3)}
.phint{font-size:10px;color:var(--t3);margin-bottom:14px;text-align:center;line-height:1.6}
.phint b{color:var(--t2)}
.lerr{font-size:11px;color:var(--skip);font-weight:500;
  text-align:center;min-height:18px;margin-bottom:12px}
.lbtn{width:100%;padding:13px;background:var(--apex);border:none;
  border-radius:10px;color:white;font-family:var(--font);font-size:13px;
  font-weight:700;cursor:pointer;transition:all .15s;letter-spacing:.3px}
.lbtn:hover{background:var(--sapp)}
.lbtn:active{transform:scale(.98)}
.slink{text-align:center;margin-top:14px;font-size:10.5px;color:var(--t3)}
.slink button{background:none;border:none;color:var(--apex);cursor:pointer;
  font-family:var(--font);font-size:10.5px;font-weight:500;text-decoration:underline;padding:0}

/* APP */
#ap{display:none;height:100%;flex-direction:column}
#ap.on{display:flex}

/* SYNC RIBBON */
.sr{background:var(--iron);height:22px;display:flex;align-items:center;
  padding:0 16px;gap:7px;flex-shrink:0;font-size:9.5px}
.sd{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.sd.ok{background:#5dca8a}.sd.busy{background:#f0c040;animation:bk .7s infinite}
.sd.err{background:#f07060}.sd.off{background:rgba(220,227,235,.25)}
@keyframes bk{0%,100%{opacity:1}50%{opacity:.3}}
.sm{flex:1;color:rgba(220,227,235,.6)}
.sl{color:rgba(220,227,235,.9);cursor:pointer;text-decoration:underline;font-weight:500}
.sl.hide{display:none}

/* HEADER */
.hdr{height:54px;background:var(--iron);display:flex;align-items:center;
  padding:0 18px;gap:14px;flex-shrink:0;border-bottom:1px solid rgba(255,255,255,.07)}
.hdr img{height:26px;width:auto}
.hdv{width:1px;height:22px;background:rgba(220,227,235,.15)}
.htit{font-size:12.5px;font-weight:700;color:var(--wh);letter-spacing:.3px}
.hsub{font-size:9px;color:rgba(220,227,235,.45);margin-top:1px}
.hr{margin-left:auto;display:flex;align-items:center;gap:8px}
.hpill{font-size:9.5px;color:rgba(220,227,235,.65);background:rgba(220,227,235,.08);
  padding:4px 10px;border-radius:20px;border:1px solid rgba(220,227,235,.12);font-weight:500}
.hbtn{display:flex;align-items:center;gap:5px;background:rgba(220,227,235,.08);
  border:1px solid rgba(220,227,235,.14);border-radius:7px;padding:5px 11px;cursor:pointer;
  color:rgba(220,227,235,.7);font-size:10px;font-family:var(--font);font-weight:500;transition:all .15s}
.hbtn:hover{background:rgba(220,227,235,.16);color:var(--wh)}
.hbtn.dng:hover{border-color:rgba(224,89,42,.4);color:#f08060}
.hbtn svg{width:13px;height:13px;flex-shrink:0}

/* TABS */
.tabs{background:var(--surf);border-bottom:1.5px solid var(--bd);
  display:flex;padding:0 16px;flex-shrink:0;overflow-x:auto}
.tabs::-webkit-scrollbar{display:none}
.tab{padding:11px 12px;font-size:10.5px;font-weight:500;color:var(--t3);cursor:pointer;
  border-bottom:2.5px solid transparent;transition:all .15s;white-space:nowrap;
  display:flex;align-items:center;gap:5px}
.tab:hover{color:var(--t2)}.tab.on{color:var(--apex);border-bottom-color:var(--apex);font-weight:700}
.tn{font-size:9px;padding:2px 6px;border-radius:10px;background:var(--panel);
  color:var(--t3);border:1px solid var(--bd);transition:all .15s}
.tab.on .tn{background:var(--apex);color:white;border-color:var(--apex)}

/* CONTENT */
.content{flex:1;display:flex;overflow:hidden}

/* STOP PANEL */
.sp{width:276px;background:var(--surf);border-right:1.5px solid var(--bd);
  display:flex;flex-direction:column;flex-shrink:0}
.sptop{padding:10px 14px 9px;border-bottom:1px solid var(--bd)}
.sptit{font-size:10.5px;font-weight:700;color:var(--apex);
  text-transform:uppercase;letter-spacing:.9px}
.spsub{font-size:9.5px;color:var(--t3);margin-top:2px}

/* PROGRESS */
.prog{padding:10px 14px;border-bottom:1px solid var(--bd);background:var(--panel)}
.prow{display:flex;justify-content:space-between;margin-bottom:5px}
.plbl{font-size:9.5px;color:var(--t2);font-weight:500}
.ppct{font-size:10px;color:var(--done);font-weight:700}
.pbar{height:4px;background:var(--bd2);border-radius:2px;overflow:hidden}
.pfil{height:100%;background:var(--done);border-radius:2px;transition:width .4s}
.qrow{display:flex;gap:5px;margin-top:7px}
.qp{flex:1;text-align:center;font-size:8px;font-weight:700;padding:3px 4px;
  border-radius:5px;letter-spacing:.3px;text-transform:uppercase}
.qa{background:var(--a-bg);color:var(--a-tx);border:1px solid var(--a-bd)}
.qb{background:var(--b-bg);color:var(--b-tx);border:1px solid var(--b-bd)}
.qc{background:var(--c-bg);color:var(--c-tx);border:1px solid var(--c-bd)}

/* STOP LIST */
.sl2{overflow-y:auto;flex:1}
.sl2::-webkit-scrollbar{width:3px}
.sl2::-webkit-scrollbar-thumb{background:var(--bd2);border-radius:3px}
.si{padding:9px 14px;border-bottom:1px solid var(--bd);cursor:pointer;
  display:flex;align-items:flex-start;gap:9px;transition:background .1s;
  border-left:3px solid transparent}
.si:hover{background:var(--hover)}
.si.done{border-left-color:var(--done)}
.si.skipped{border-left-color:var(--skip);opacity:.7}
.si.planned{border-left-color:var(--bd)}
.sn{width:24px;height:24px;border-radius:50%;flex-shrink:0;margin-top:1px;
  display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700}
.sna{background:var(--a-bg);color:var(--a-tx);border:1.5px solid var(--a-bd)}
.snb{background:var(--b-bg);color:var(--b-tx);border:1.5px solid var(--b-bd)}
.snc{background:var(--c-bg);color:var(--c-tx);border:1.5px solid var(--c-bd)}
.sb{flex:1;min-width:0}
.sname{font-size:11px;font-weight:500;color:var(--t1);
  white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.smeta{font-size:9.5px;color:var(--t3);margin-top:2px;display:flex;gap:5px;align-items:center}
.ttag{font-weight:700;font-size:8.5px;text-transform:uppercase}
.ck{flex-shrink:0;width:22px;height:22px;border-radius:6px;
  border:1.5px solid var(--bd2);background:white;cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  transition:all .15s;margin-top:1px}
.ck:hover{border-color:var(--done);background:#eaf3de}
.ck.done{background:var(--done);border-color:var(--done)}
.ck.skip{background:var(--skip);border-color:var(--skip)}
.ck svg{width:11px;height:11px;display:block}

/* MAP */
#map{flex:1;z-index:1}

/* STATS */
.stats{background:var(--iron);border-top:1px solid rgba(255,255,255,.07);
  padding:6px 18px;display:flex;gap:20px;align-items:center;flex-shrink:0;flex-wrap:wrap}
.st{font-size:10px;color:rgba(220,227,235,.5)}
.st b{color:var(--wh);font-weight:700}
.st.g b{color:#5dca8a}.st.r b{color:#f08070}.st.a b{color:#f5d060}

/* DRAWER */
.drw{position:absolute;right:0;top:76px;width:294px;
  height:calc(100% - 76px);background:var(--surf);
  border-left:1.5px solid var(--bd);transform:translateX(100%);
  transition:transform .22s ease;z-index:50;display:flex;flex-direction:column;
  box-shadow:-6px 0 20px rgba(1,30,65,.08)}
.drw.open{transform:translateX(0)}
.dtop{padding:12px 16px;border-bottom:1px solid var(--bd);background:var(--panel);
  display:flex;align-items:center;justify-content:space-between}
.dtit{font-size:9.5px;font-weight:700;color:var(--apex);
  text-transform:uppercase;letter-spacing:.9px}
.dx{background:none;border:none;cursor:pointer;color:var(--t3);
  display:flex;align-items:center;padding:4px;border-radius:5px;transition:all .15s}
.dx:hover{background:var(--hover);color:var(--t1)}
.dbody{padding:14px 16px;overflow-y:auto;flex:1}
.dbody::-webkit-scrollbar{width:3px}
.dbody::-webkit-scrollbar-thumb{background:var(--bd2)}
.tbdg{display:inline-flex;align-items:center;padding:3px 10px;border-radius:20px;
  font-size:8.5px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;margin-bottom:8px}
.tba{background:var(--a-bg);color:var(--a-tx);border:1px solid var(--a-bd)}
.tbb{background:var(--b-bg);color:var(--b-tx);border:1px solid var(--b-bd)}
.tbc{background:var(--c-bg);color:var(--c-tx);border:1px solid var(--c-bd)}
.dname{font-size:14px;font-weight:700;color:var(--t1);margin-bottom:3px;line-height:1.3}
.did{font-size:9.5px;color:var(--t3);font-family:monospace;margin-bottom:14px}
.dsec{margin-bottom:13px}
.dslbl{font-size:8.5px;font-weight:700;color:var(--t3);text-transform:uppercase;
  letter-spacing:1px;margin-bottom:6px;border-bottom:1px solid var(--bd);padding-bottom:4px}
.dr{display:flex;justify-content:space-between;align-items:center;
  padding:5px 0;border-bottom:1px solid var(--panel)}
.dr:last-child{border-bottom:none}
.dk{font-size:10.5px;color:var(--t2)}.dv{font-size:10.5px;color:var(--t1);font-weight:500;font-family:monospace}
.dnote{font-size:11px;color:var(--t2);line-height:1.6;background:var(--panel);
  border-radius:8px;padding:9px 11px;border:1px solid var(--bd);font-style:italic}
.vbtns{display:flex;gap:8px;margin:14px 0 0}
.vb{flex:1;padding:9px;border-radius:8px;font-size:11px;font-weight:700;
  cursor:pointer;border:1.5px solid;font-family:var(--font);letter-spacing:.3px;transition:all .15s}
.vbd{background:#eaf3de;border-color:#97c459;color:#1a5e2a}
.vbd:hover,.vbd.on{background:var(--done);border-color:var(--done);color:white}
.vbs{background:#fdeaea;border-color:#e09595;color:#8b1a1a}
.vbs:hover,.vbs.on{background:var(--skip);border-color:var(--skip);color:white}
.vsn{font-size:10px;font-weight:500;margin-top:8px;padding:7px 11px;
  border-radius:7px;display:flex;align-items:center;gap:6px}
.vsnd{background:#eaf3de;color:#1a5e2a;border:1px solid #97c459}
.vsns{background:#fdeaea;color:#8b1a1a;border:1px solid #e09595}
.ilbl{display:block;font-size:9px;font-weight:700;color:var(--t3);
  text-transform:uppercase;letter-spacing:.9px;margin-top:12px;margin-bottom:5px}
.dinp{width:100%;background:var(--panel);border:1.5px solid var(--bd2);
  border-radius:8px;padding:8px 11px;color:var(--t1);font-family:var(--font);
  font-size:12px;outline:none;transition:border-color .15s}
.dinp:focus{border-color:var(--apex)}.dinp::placeholder{color:var(--t3)}
textarea.dinp{resize:vertical;min-height:62px;line-height:1.5}
.synote{margin-top:10px;font-size:9.5px;display:flex;align-items:center;gap:5px;
  color:var(--t3);padding:7px 10px;background:var(--panel);border-radius:7px;border:1px solid var(--bd)}
.synote a{color:var(--apex);cursor:pointer;font-weight:500}
.syndot{width:6px;height:6px;border-radius:50%;flex-shrink:0}

/* EMPTY */
.empty{flex:1;display:flex;flex-direction:column;align-items:center;
  justify-content:center;gap:10px;color:var(--t3);padding:24px;text-align:center}
.empty p{font-size:11.5px;line-height:1.6}

/* LEAFLET */
.leaflet-popup-content-wrapper{background:var(--iron);color:var(--wh);border:none;
  border-radius:10px;box-shadow:0 8px 30px rgba(1,30,65,.3)}
.leaflet-popup-tip{background:var(--iron)}
.leaflet-popup-content{margin:10px 14px;font-family:var(--font);font-size:11.5px}
.lpt{font-size:8px;font-weight:700;letter-spacing:.6px;text-transform:uppercase;margin-bottom:3px}
.lpn{font-weight:700;color:var(--wh);margin-bottom:2px;font-size:12px}
