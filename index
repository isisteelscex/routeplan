    div.querySelector('.ck').addEventListener('click',function(e){
      e.stopPropagation();
      quickTick(this.dataset.cid, parseInt(this.dataset.idx));
    });
    div.addEventListener('click',function(){ openDrawer(s,i); });
    el.appendChild(div);
  });
}
function ckS(){ return '<svg viewBox="0 0 11 11" fill="none"><polyline points="1.5,5.5 4.5,8.5 9.5,2.5" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>'; }
function xS(){ return '<svg viewBox="0 0 11 11" fill="none"><line x1="2" y1="2" x2="9" y2="9" stroke="white" stroke-width="1.8" stroke-linecap="round"/><line x1="9" y1="2" x2="2" y2="9" stroke="white" stroke-width="1.8" stroke-linecap="round"/></svg>'; }

function quickTick(cid,idx){
  var stops=curExec.days[curDay]||[];
  var s=stops.find(function(x){ return x.id===cid; }); if(!s) return;
  var cur=getS(s).status;
  var nxt=cur==='planned'?'done':cur==='done'?'skipped':'planned';
  var st=getS(s); setS(s,{status:nxt});
  renderStops(stops); renderMap(stops); updateStats(stops);
  syncLog(s,nxt,st.order,st.notes,idx);
  if(selStop&&selStop.id===cid) openDrawer(s,stops.findIndex(function(x){ return x.id===cid; }));
}
function updateProg(stops){
  var done=stops.filter(function(s){ return getS(s).status==='done'; }).length;
  var pct=stops.length?Math.round(done/stops.length*100):0;
  document.getElementById('plbl').textContent=done+' of '+stops.length+' visited';
  document.getElementById('ppct').textContent=pct+'%';
  document.getElementById('pfil').style.width=pct+'%';
  var a=stops.filter(function(s){ return s.tier==='A'; });
  var b=stops.filter(function(s){ return s.tier==='B'; });
  var c=stops.filter(function(s){ return s.tier==='C'; });
  document.getElementById('qrow').innerHTML=
    '<div class="qp qa">A '+a.filter(function(s){ return getS(s).status==='done'; }).length+'/'+a.length+'</div>'+
    '<div class="qp qb">B '+b.filter(function(s){ return getS(s).status==='done'; }).length+'/'+b.length+'</div>'+
    '<div class="qp qc">C '+c.filter(function(s){ return getS(s).status==='done'; }).length+'/'+c.length+'</div>';
}

// MAP
function renderMap(stops){
  markers.forEach(function(m){ map.removeLayer(m); }); markers=[];
  if(rLine){ map.removeLayer(rLine); rLine=null; }
  if(!stops.length) return;
  var lls=[];
  stops.forEach(function(s,i){
    var st=getS(s).status;
    var tc=TC[s.tier];
    var isDone=st==='done',isSkip=st==='skipped';
    var bg=isDone?'#2c9942':isSkip?'#c0392b':tc;
    var bd=isDone?'2px solid #1a5e2a':isSkip?'2px solid #8b1a1a':'2px solid rgba(1,30,65,.2)';
    var ll=[s.lat,s.lon]; lls.push(ll);
    var icon=L.divIcon({
      html:'<div style="width:26px;height:26px;border-radius:50%;background:'+bg+';'+bd+
           ';display:flex;align-items:center;justify-content:center;'+
           'font-family:sans-serif;font-size:9px;font-weight:700;color:white;'+
           'box-shadow:0 2px 8px rgba(1,30,65,.2)">'+
           (isDone?'✓':isSkip?'×':(i+1))+'</div>',
      className:'',iconSize:[26,26],iconAnchor:[13,13]
    });
    var tl=s.tier==='A'?'High Value':s.tier==='B'?'Medium Value':'Low Value';
    var sl=isDone?'<span style="color:#5dca8a;font-weight:700">✓ Visited</span>':
           isSkip?'<span style="color:#f08070;font-weight:700">⊘ Skipped</span>':
           '<span style="color:rgba(220,227,235,.5)">○ Planned</span>';
    var mk=L.marker(ll,{icon}).addTo(map);
    mk.bindPopup('<div class="lpt" style="color:'+tc+'">Tier '+s.tier+' · '+tl+'</div>'+
      '<div class="lpn">'+s.name+'</div><div class="lpi">'+s.id+'</div>'+
      '<div class="lps">'+sl+'</div>');
    markers.push(mk);
  });
  rLine=L.polyline(lls,{color:'#004a98',weight:1.5,opacity:.3,dashArray:'5,5'}).addTo(map);
  map.fitBounds(L.latLngBounds(lls).pad(0.12));
}

// STATS
function updateStats(stops){
  var done=stops.filter(function(s){ return getS(s).status==='done'; }).length;
  var skip=stops.filter(function(s){ return getS(s).status==='skipped'; }).length;
  var orders=stops.reduce(function(a,s){ var st=getS(s); return a+(st.status==='done'?(st.order||0):0); },0);
  var km=rKm(stops);
  var aOk=stops.filter(function(s){ return s.tier==='A'; }).every(function(s){ return getS(s).status!=='skipped'; });
  document.getElementById('stats').innerHTML=
    '<div class="st"><b>'+curDay+'</b></div>'+
    '<div class="st">Stops <b>'+stops.length+'</b></div>'+
    '<div class="st g">Done <b>'+done+'</b></div>'+
    '<div class="st r">Skipped <b>'+skip+'</b></div>'+
    '<div class="st a">Tier A <b>'+(aOk?'All ✓':'⚠ Check')+'</b></div>'+
    '<div class="st">Route <b>~'+km+' km</b></div>'+
    (orders?'<div class="st g">Orders <b>$'+orders.toLocaleString()+'</b></div>':'');
}
function rKm(stops){
  if(stops.length<2) return 0;
  var t=0;
  for(var i=1;i<stops.length;i++) t+=hav(stops[i-1].lat,stops[i-1].lon,stops[i].lat,stops[i].lon);
  return t.toFixed(1);
}
function hav(a,b,c,d){
  var R=6371,p=Math.PI/180,da=(c-a)*p,db=(d-b)*p;
  var x=Math.sin(da/2)*Math.sin(da/2)+Math.cos(a*p)*Math.cos(c*p)*Math.sin(db/2)*Math.sin(db/2);
  return R*2*Math.atan2(Math.sqrt(x),Math.sqrt(1-x));
}

// DRAWER
function openDrawer(s,idx){
  selStop=s;
  var st=getS(s);
  var tb='tb'+s.tier.toLowerCase();
  var tl=s.tier==='A'?'High Value':s.tier==='B'?'Medium Value':'Low Value';
  var stops=curExec.days[curDay]||[];
  var sn=GS?
    '<div class="synote"><div class="syndot" style="background:#5dca8a"></div>Auto-saves to Google Sheets</div>':
    '<div class="synote"><div class="syndot" style="background:var(--t3)"></div>Not syncing &mdash; <a onclick="openModal()">connect Sheets</a></div>';
  document.getElementById('dbody').innerHTML=
    '<div class="tbdg '+tb+'">Tier '+s.tier+' &bull; '+tl+'</div>'+
    '<div class="dname">'+s.name+'</div>'+
    '<div class="did">ID: '+s.id+'</div>'+
    '<div class="dsec"><div class="dslbl">Stop info</div>'+
    '<div class="dr"><span class="dk">Position</span><span class="dv">#'+(idx+1)+' of '+stops.length+'</span></div>'+
    '<div class="dr"><span class="dk">Day</span><span class="dv">'+curDay+'</span></div>'+
    '<div class="dr"><span class="dk">GPS</span><span class="dv">'+s.lat.toFixed(4)+', '+s.lon.toFixed(4)+'</span></div></div>'+
    (s.notes&&s.notes!=='None'?'<div class="dsec"><div class="dslbl">Notes</div><div class="dnote">'+s.notes+'</div></div>':'')+
    '<div class="dsec"><div class="dslbl">Record visit</div>'+
    '<div class="vbtns">'+
    '<button class="vb vbd'+(st.status==='done'?' on':'')+'" onclick="drwSt('done')">✓ Done</button>'+
    '<button class="vb vbs'+(st.status==='skipped'?' on':'')+'" onclick="drwSt('skipped')">⊘ Skip</button>'+
    '</div>'+
    (st.status==='done'?'<div class="vsn vsnd">✓ Marked as visited</div>':
     st.status==='skipped'?'<div class="vsn vsns">⊘ Skipped &mdash; flagged for follow-up</div>':'')+
    '<label class="ilbl">Order value (USD)</label>'+
    '<input class="dinp" type="number" min="0" placeholder="Enter amount..." id="oi" value="'+(st.order||'')+'" data-idx="'+idx+'">'+
    '<label class="ilbl">Visit notes</label>'+
    '<textarea class="dinp" placeholder="What happened..." id="ni" data-idx="'+idx+'">'+(st.notes||'')+'</textarea>'+
    '</div>'+sn;
  document.getElementById('drw').classList.add('open');
  document.getElementById('oi').addEventListener('input',function(){ drwOrd(this.value,parseInt(this.dataset.idx)); });
  document.getElementById('ni').addEventListener('input',function(){ drwNote(this.value,parseInt(this.dataset.idx)); });
  if(markers[idx]){ map.setView(markers[idx].getLatLng(),14,{animate:true}); markers[idx].openPopup(); }
}
function drwSt(s){
  if(!selStop) return;
  var st=getS(selStop); setS(selStop,{status:s});
  var stops=curExec.days[curDay]||[];
  var idx=stops.findIndex(function(x){ return x.id===selStop.id; });
  renderStops(stops); renderMap(stops); updateStats(stops);
  syncLog(selStop,s,st.order,st.notes,idx);
  openDrawer(selStop,idx);
}
function drwOrd(v,idx){
  if(!selStop) return;
  var order=parseInt(v)||0; setS(selStop,{order:order});
  updateStats(curExec.days[curDay]||[]);
  var st=getS(selStop); syncLog(selStop,st.status,order,st.notes,idx);
}
function drwNote(v,idx){
  if(!selStop) return;
  setS(selStop,{notes:v});
  var st=getS(selStop); syncLog(selStop,st.status,st.order,v,idx);
}
function closeDrawer(){ document.getElementById('drw').classList.remove('open'); selStop=null; }
</script></body></html>
